# ==========================================
# Git Ignore for Multi-Stack Project
# Java (Spring Boot + Gradle), Python, and JS Frontend
# ==========================================

# ------------------------------------------
# Operating System files
# ------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ------------------------------------------
# IDEs and Editors
# ------------------------------------------
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Eclipse
.metadata/
.classpath
.project
.settings/
*.launch

# NetBeans
/nbproject/private/
/build/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ------------------------------------------
# Java / Gradle (Spring Boot)
# ------------------------------------------
.gradle/
build/
bin/
!gradle-wrapper.jar

# Crashlytics gem (Android/Java development)
crashlytics-platform.properties
crashlytics-execution.properties

# ------------------------------------------
# Python (Server)
# ------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so they can be ignored.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff (if Django is used)
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff (if Flask is used)
instance/
.webassets-cache

# Scrapy stuff
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, you might want to ignore it.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing a platform-specific build, you may choose to ignore it.
#Pipfile.lock

# poetry
#   Poetry uses pyproject.toml and poetry.lock. Both should be committed.

# pdm
#   PDM stores project-wide configurations in .pdm.toml
.pdm.toml
.pdm-python
.pdm-build/

# pipx
.pipx/

# Virtual Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyder-py3

# Rope project settings
.ropeproject

# mkdocs documentation
/site/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static analyzer
.pytype/

# Cython debug symbols
cython_debug/

# ------------------------------------------
# Frontend / Javascript (HTML, CSS, JS)
# ------------------------------------------
# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Snowpack dependency directory
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Output directories (standard build folders)
dist/
tmp/
out-tsc/
.nuxt/
.next/
.docusaurus/
.svelte-kit/

# Serverless Webpack directories
.webpack/

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov/

# Coverage directory used by tools like istanbul
coverage/
.nyc_output/

# Gatsby files
.cache/
public/

# vuepress files
.vuepress/dist

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Tern JS port file
.tern-port

# Yalc storage
.yalc

# ------------------------------------------
# Environment Variables & Secrets (Universal)
# ------------------------------------------
.env
.env.accounts
.env.backup
.env.development.local
.env.local
.env.production.local
.env.test.local
.env.production
.env.development
*.env
*.secrets
